<view class="page">
  <view class="title" style="color: {{titleColor}};">
    {{title}}
  </view>

  <view class="subtitle">
    {{subtitle}}
  </view>

  <view class="progress-text">
    Progreso final: {{progress}} / {{maxProgress}}
  </view>

  <view class="retry-button" onTap="retryGame">
    REINTENTAR
  </view>

  <view class="menu-button" onTap="goMenu">
    MENÚ
  </view>
</view>
