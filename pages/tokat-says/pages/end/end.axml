<view class="page">
  <view class="title">RESULTADO</view>

  <view class="card">
    <view class="round-text">Llegaste a la ronda {{round}}</view>
    <view class="tokens-text">🪙 Tokens ganados: {{tokens}}</view>
    <view class="sequence-text">Secuencia final: {{sequenceLen}} gestos</view>
  </view>

  <view class="retry-button" onTap="retryGame">
    REINTENTAR
  </view>

  <view class="menu-button" onTap="goMenu">
    MENÚ
  </view>
</view>
